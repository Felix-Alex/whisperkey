{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "WhisperKey",
  "version": "0.1.0",
  "identifier": "app.whisperkey",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "WhisperKey",
        "width": 860,
        "height": 600,
        "visible": true,
        "center": true
      },
      {
        "label": "indicator",
        "url": "/indicator",
        "width": 200,
        "height": 40,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "focus": false,
        "visible": false,
        "resizable": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "nsis",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "installerIcon": "icons/icon.ico"
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://update.whisperkey.app/v1/{{target}}/latest.json"
      ],
      "pubkey": ""
    }
  }
}
