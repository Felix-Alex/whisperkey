{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "WhisperKey",
  "version": "2.1.6",
  "identifier": "app.whisperkey",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "WhisperKey",
        "width": 860,
        "height": 600,
        "visible": true,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; connect-src 'self' https://api.openai.com https://api.deepseek.com https://api.anthropic.com https://generativelanguage.googleapis.com https://aip.baidubce.com wss://openspeech.bytedance.com https://api.xfyun.cn https://raasr.xfyun.cn"
    }
  },
  "bundle": {
    "active": true,
    "targets": "nsis",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "installerIcon": "icons/icon.ico",
        "languages": ["SimpChinese", "English"],
        "displayLanguageSelector": true,
        "startMenuFolder": "语灵听写 WhisperKey"
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://update.whisperkey.app/v1/{{target}}/latest.json"
      ],
      "pubkey": ""
    }
  }
}
